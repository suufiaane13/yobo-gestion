{
  "productName": "yobo-gestion",
  "version": "2.6.0",
  "identifier": "com.yobo.gestion",
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "YOBO Gestion",
        "width": 1280,
        "height": 800,
        "minWidth": 980,
        "minHeight": 640,
        "decorations": false,
        "resizable": true,
        "minimizable": false,
        "maximizable": false,
        "fullscreen": true
      }
    ],
    "security": {
      "capabilities": [
        "main-capability"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "publisher": "YOBO",
    "copyright": "© YOBO — Gestion snack",
    "shortDescription": "Caisse et gestion pour snack (données sur votre PC).",
    "longDescription": "YOBO Gestion : encaissement, menu, historique, comptes gérant et caissiers. Les données sont stockées localement sur cet ordinateur (SQLite).",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "bundle/nsis/installer-header.bmp",
        "sidebarImage": "bundle/nsis/installer-sidebar.bmp",
        "startMenuFolder": "YOBO",
        "languages": [
          "French"
        ],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/suufiaane13/yobo-gestion/main/updater/{{target}}-{{arch}}.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI0Nzc4REQ5OUMyQUFGQQpSV1Q2cXNLWjNYaEhDemtOTWVvakFIQVFqdEJqNXdmSnF6bjZ3Z1FyVE5HV2U0aGgvT3BvL1gvSAo="
    }
  }
}