    "debug:doctor": "node scripts/debug-yobo.mjs doctor",
    "debug:full": "node scripts/debug-yobo.mjs audit --full",
    "icons:generate": "npx tauri icon src-tauri/icons/512x512.png -o src-tauri/icons",
    "release:user-pack": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-user-release.ps1"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
